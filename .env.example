# Environment-variabler for estimeringsappen
# Kopier denne filen til .env.local og fyll inn verdiene

# Supabase-prosjekt URL (f.eks. https://abcdefghij.supabase.co)
# Lokalt: http://127.0.0.1:54321
VITE_SUPABASE_URL=

# Supabase anon/public key
# Lokalt: finn med `supabase status`
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile site key
# ⚠️  VIKTIG: site key og secret key MÅ komme fra samme Cloudflare-widget!
#    Test-par (begge test):
#      VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#      TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
#    Produksjons-par: hent begge fra Cloudflare Dashboard → Turnstile → <widget>
# Produksjons-secreten vil AVVISE dummy-tokens fra test-sitekey!
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Cloudflare Turnstile secret key (brukes kun server-side, ALDRI med VITE_-prefix!)
# Må matche widget-paret til VITE_TURNSTILE_SITE_KEY (se kommentar over)
# Testmodus: 1x0000000000000000000000000000000AA
# Produksjon: hent fra Cloudflare Dashboard → Turnstile → <widget> → Secret key
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
